# Banco de dados (SQLite local, montar volume no Docker)
DATABASE_URL="file:./dev.db"

# Caminho do diretório de ZIPs de fontes (para downloads)
# No Docker é montado como volume em /app/data/fonts
FONTS_ZIP_PATH="/app/data/fonts"

# Caminho dos TTFs extraídos (para pré-visualizações)
FONTS_TTF_PATH="/app/public/fonts"

# Senha do painel de administração (/admin)
ADMIN_PASSWORD="trocar-esta-senha"
